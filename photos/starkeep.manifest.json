{
  "id": "photos",
  "name": "Photos",
  "version": "0.1.0",
  "tier": "official",
  "infraRequirements": {
    "sharedTypeAccess": [
      {
        "typeId": "image",
        "access": "readwrite",
        "metadataWrite": true,
        "rationale": "Photos app stores images and writes EXIF/dimensions extracted from uploaded image files into the image metadata table."
      }
    ],
    "appSpecificSyncable": {
      "files": true,
      "tables": [
        {
          "name": "captions",
          "columns": [
            { "name": "image_id", "type": "text", "primaryKey": true, "notNull": true },
            { "name": "caption", "type": "text" }
          ]
        },
        {
          "name": "photos_user_metadata",
          "columns": [
            { "name": "record_id", "type": "text", "primaryKey": true, "notNull": true },
            { "name": "title", "type": "text" },
            { "name": "date_taken_override", "type": "text" }
          ]
        }
      ]
    }
  }
}
