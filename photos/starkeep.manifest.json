{
  "id": "photos",
  "name": "Photos",
  "version": "0.1.0",
  "tier": "official",
  "infraRequirements": {
    "sharedTypeAccess": [
      {
        "typeId": "image",
        "access": "readwrite",
        "metadataWrite": true,
        "rationale": "Photos app stores images and writes EXIF/dimensions extracted from uploaded image files into the image metadata table."
      }
    ],
    "appSpecificSyncable": {
      "files": true,
      "tables": [
        {
          "name": "image_enriched",
          "columns": [
            { "name": "record_id", "type": "text", "primaryKey": true, "notNull": true },
            { "name": "caption", "type": "text" },
            { "name": "title", "type": "text" },
            { "name": "date_taken_override", "type": "text" }
          ]
        }
      ]
    },
    "compute": {
      "enabled": true,
      "handlers": [
        {
          "name": "api",
          "handler": "infra/src/photos-handler.handler",
          "memoryMb": 512,
          "timeoutSeconds": 30,
          "routes": [
            "POST /generate",
            "GET /photos",
            "POST /photos",
            "GET /photos/{id}",
            "DELETE /photos/{id}",
            "POST /photos/crop",
            "PUT /photos/style-graphic",
            "GET /photos/style-graphic",
            "DELETE /photos/style-graphic",
            "PATCH /photos/captions/{id}"
          ]
        },
        {
          "name": "static",
          "handler": "index.handler",
          "memoryMb": 256,
          "timeoutSeconds": 10,
          "routes": ["GET /", "GET /{proxy+}"],
          "auth": "public",
          "env": {
            "STARKEEP_API_GATEWAY_URL": "",
            "STARKEEP_USER_POOL_ID": "",
            "STARKEEP_USER_POOL_CLIENT_ID": "",
            "STARKEEP_IDENTITY_POOL_ID": ""
          }
        }
      ]
    }
  }
}
